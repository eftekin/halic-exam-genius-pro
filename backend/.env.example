# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  Haliç Exam Genius Pro — Environment Variables                              ║
# ║  Copy this file to .env and fill in real values.  NEVER commit .env!        ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── App ───────────────────────────────────────────────────────────────────────
# A random secret used for signing tokens / internal auth.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
EXAM_GENIUS_SECRET_KEY=CHANGE_ME_generate_a_64_char_random_string

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Use your exact Vercel deployment URL(s).
# Example: https://exam-genius.vercel.app,https://exam-genius-staging.vercel.app
EXAM_GENIUS_CORS_ORIGINS=https://your-app.vercel.app

# ── Exam Schedule Source ──────────────────────────────────────────────────────
# URL is set in backend/app/config.py. Do NOT set it here — update config.py and
# deploy so the app uses the value from code (single source of truth).

# ── Cache ─────────────────────────────────────────────────────────────────────
EXAM_GENIUS_CACHE_TTL_SECONDS=3600

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=exam_genius
POSTGRES_PASSWORD=CHANGE_ME_use_a_strong_password
POSTGRES_DB=exam_genius_db
EXAM_GENIUS_DATABASE_URL=postgresql://exam_genius:CHANGE_ME_use_a_strong_password@db:5432/exam_genius_db
