# ╔══════════════════════════════════════════════════════════════════╗
# ║  Haliç Exam Genius Pro — Root .gitignore                        ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── OS files ──────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── IDEs & Editors ───────────────────────────────────────────────
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ── Environment variables ────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python / Backend ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl

# Virtual environments
.venv/
venv/
env/
ENV/

# Python tools
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# IPython / Jupyter
.ipynb_checkpoints/
*.ipynb

# ── Node / Frontend ──────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js
.next/
out/

# Build output
build/
dist/

# Testing
coverage/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# TypeScript
*.tsbuildinfo

# Vercel
.vercel

# ── Misc ─────────────────────────────────────────────────────────
*.pem
*.log
*.tmp
*.bak
*.orig
